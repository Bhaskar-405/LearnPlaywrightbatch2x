var a = 10; // Global Scope
console.log(a);
// Defination of the function
function printHello() {
    console.log("Hello TheTestingAcademy!");
    var a = 20; // Local Scope
    console.log(a);
    //block begins
    if (true) {
        var a = 30;
        console.log(a); // 30
    }
    //block ends
    console.log("F ->", a);
}
//function ends
console.log("G ->", a);

printHello();